            "exec": [
              "pm.test(\"Sikeresen a lekérés\",function(){\r",
              "    pm.response.to.have .status(200);\r",
              "}\r",
              ")\r",
              "pm.test(\"Lekérés megfelelő adatot tartalmaz\",function(){\r",
              "    const valasz = pm.response.json();\r",
              "    pm.expect(valasz).to.have.property(\"nev\");\r",
              "    pm.expect(valasz).to.have.property(\"nevEn\");\r",
              "    pm.expect(valasz).to.have.property(\"leiras\");\r",
              "    pm.expect(valasz).to.have.property(\"leirasEn\");\r",
              "    pm.expect(valasz).to.have.property(\"ar\");\r",
              "    pm.expect(valasz).to.have.property(\"kategoriaId\");\r",
              "    pm.expect(valasz).to.have.property(\"keszlet\");\r",
              "    pm.expect(valasz).to.have.property(\"learazasid\");\r",
              "}\r",
              ")\r",
              "pm.test(\"Lekérés megfelelő terméket ad vissza\",function(){\r",
              "    const valasz = pm.response.json();\r",
              "    pm.expect(valasz.nev).to.eql(\"Vadhús hűtőtáska\");\r",
              "})\r",
              "pm.test(\"Van raktáron\",function(){\r",
              "    const valasz = pm.response.json();\r",
              "    pm.expect(valasz.keszlet).greaterThan(0)\r",
              "}\r",
              ")"
